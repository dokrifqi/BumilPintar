{
  "version": 2,
  "builds": [
    { "src": "bumil_pintar.html", "use": "@vercel/static" },
    { "src": "manifest.json",     "use": "@vercel/static" },
    { "src": "sw.js",             "use": "@vercel/static" },
    { "src": "icon-192.png",      "use": "@vercel/static" },
    { "src": "icon-512.png",      "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/sw.js",
      "dest": "/sw.js",
      "headers": { "Service-Worker-Allowed": "/", "Cache-Control": "no-cache" }
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json",
      "headers": { "Content-Type": "application/manifest+json" }
    },
    { "src": "/icon-(.*)\\.png", "dest": "/icon-$1.png" },
    { "src": "/",                "dest": "/bumil_pintar.html" },
    { "src": "/(.*)",            "dest": "/bumil_pintar.html" }
  ]
}
